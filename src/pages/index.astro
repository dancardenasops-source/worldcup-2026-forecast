---
import BroadcastDashboard from "../components/broadcast/BroadcastDashboard.jsx";
import "../styles/broadcast.css";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>World Cup 2026: Knockout Forecast</title>
    <meta
      name="description"
      content="Live 2026 FIFA World Cup knockout bracket, title probabilities, final group standings and the Golden Boot race."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content="World Cup 2026: Knockout Forecast" />
    <meta property="og:description" content="Interactive bracket and title-probability model for the 2026 FIFA World Cup." />
    <meta property="og:type" content="website" />
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        background: #141822;
      }
    </style>
  </head>
  <body>
    <BroadcastDashboard client:load />
  </body>
</html>
