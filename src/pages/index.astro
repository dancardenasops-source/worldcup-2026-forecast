---
import Dashboard from "../components/Dashboard.jsx";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>World Cup 2026 — Knockout Forecast</title>
    <meta
      name="description"
      content="Live 2026 FIFA World Cup knockout bracket, de-vigged title probabilities, final group standings and the Golden Boot race. Updated June 29, 2026."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content="World Cup 2026 — Knockout Forecast" />
    <meta
      property="og:description"
      content="Interactive bracket and unbiased title-probability model for the 2026 FIFA World Cup."
    />
    <meta property="og:type" content="website" />
    <style>
      html,
      body {
        margin: 0;
        padding: 0;
        background: #0b1622;
      }
    </style>
  </head>
  <body>
    <!-- client:load hydrates the dashboard so tabs, the scrollable bracket and the methodology panel work -->
    <Dashboard client:load />
  </body>
</html>
